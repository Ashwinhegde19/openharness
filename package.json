{
  "name": "openharness",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "Session-scoped, provider-neutral launcher for Claude Code, OpenCode, Codex, and Pi Code",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:bundle": "bash scripts/build-bundle.sh",
    "build:site": "pnpm build:bundle && pnpm --dir site exec convex codegen --typecheck disable && pnpm --filter @openharness/site build",
    "build:site:preview": "pnpm build:bundle && pnpm --filter @openharness/site build",
    "matrix:validate": "node scripts/validate-matrix.mjs",
    "matrix:render": "node scripts/render-matrix.mjs",
    "bump-version": "bash scripts/bump-version.sh",
    "dev": "pnpm -F @openharness/cli dev",
    "dev:site": "pnpm --filter @openharness/site dev",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "hooks:install": "lefthook install",
    "test": "pnpm -F @openharness/tests test",
    "bench:proxy": "pnpm -F @openharness/tests bench:proxy",
    "capture:proxy-fixtures": "pnpm -F @openharness/tests capture:proxy-fixtures",
    "watch": "pnpm dev",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "lefthook": "2.1.9",
    "oxfmt": "0.57.0",
    "turbo": "^2.10.1",
    "typescript": "7.0.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.9.0"
}
